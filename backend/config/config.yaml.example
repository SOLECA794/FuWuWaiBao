server:
  port: 8080
  mode: debug

database:
  driver: postgres
  host: localhost
  port: 5432
  user: postgres
  password: 123456
  dbname: teaching
  sslmode: disable

redis:
  host: localhost
  port: 6379
  password: ""
  db: 0

oss:
  provider: minio
  endpoint: http://localhost:9000
  access_key: minioadmin
  secret_key: minioadmin
  bucket: teaching
  use_ssl: false

ai:
  provider: mock
  api_key: ""
  model: ""

log:
  level: info
  filename: logs/app.log
