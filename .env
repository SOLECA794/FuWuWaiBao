# ==============================================================================
# 泛雅 AI 智课系统 环境变量示例文件 (.env.example)
# ==============================================================================
# 说明：
# 1. 复制本文件为 .env 以供 Docker Compose 和 后端使用。
# 2. 如果需本机私有配置（如不同的 IP 或 API Key），请创建 .env.local 覆盖。
# 3. 后端配置优先级：系统变量 > .env.local > .env > YAML 文件。

# ------------------------------------------------------------------------------
# 1. AI 接口配置 (AI Engine / LLM Provider)
# ------------------------------------------------------------------------------
AI_API_KEY=sk-your-key-here
# AI 引擎内部调用的大模型网关地址（给 ai_engine 使用）
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 后端调用 AI 引擎服务地址（给 backend 使用）
AI_ENGINE_BASE_URL=http://localhost:8000
AI_MODEL=qwen-turbo
# 生成模式: mock (本地模拟) | llm (调用接口)
AI_GEN_MODE=llm

# ------------------------------------------------------------------------------
# 2. 数据库配置 (Postgres)
# ------------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=123456
DB_NAME=teaching
DB_SSLMODE=disable

# ------------------------------------------------------------------------------
# 3. 缓存配置 (Redis)
# ------------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ------------------------------------------------------------------------------
# 4. 对象存储配置 (MinIO / OSS)
# ------------------------------------------------------------------------------
# 如果是在 Docker Compose 中连接，且 MinIO 网络别名为 minio，则用 minio:9000
# 如果是宿主机运行后端，则通常用 localhost:9000
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=teaching
MINIO_USE_SSL=false

# ------------------------------------------------------------------------------
# 5. 后端 Server 配置
# ------------------------------------------------------------------------------
SERVER_PORT=18080
SERVER_MODE=debug
LOG_LEVEL=info
